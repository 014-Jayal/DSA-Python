class Solution:
    def kBitFlips(self, arr, k):
        n = len(arr)
        flip = [0] * n
        curr_flips = 0
        ans = 0
        
        for i in range(n):
            if i >= k:
                curr_flips ^= flip[i-k]
            
            if arr[i] ^ curr_flips == 0:
                if i + k > n:
                    return -1
                ans += 1
                curr_flips ^= 1
                flip[i] = 1
        
        return ans
        
